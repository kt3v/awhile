{
  "name": "awhile",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "concurrently -k -n \"vite,api\" -c \"cyan,yellow\" \"vite\" \"node server/index.js\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "node start.js",
    "electron:dev": "tsc -p tsconfig.electron.json && concurrently -k -n \"vite,api,electron\" -c \"cyan,yellow,blue\" \"vite\" \"node server/index.js\" \"electron .\"",
    "electron:build": "npm run build && tsc -p tsconfig.electron.json && electron-builder",
    "electron:preview": "tsc -p tsconfig.electron.json && electron ."
  },
  "dependencies": {
    "@tiptap/extension-image": "^3.23.4",
    "@tiptap/extension-placeholder": "^3.23.4",
    "@tiptap/pm": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "build": {
    "appId": "com.awhile.app",
    "productName": "Awhile",
    "asar": true,
    "compression": "maximum",
    "files": [
      "dist/**/*",
      "electron-dist/**/*",
      "server/**/*",
      "!node_modules/**/*.{md,ts,map}",
      "!node_modules/**/test{s,}/**",
      "!node_modules/**/{example,examples,demo,demos}/**"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
